# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/**/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*
# 忽略引擎生成的临时文件夹
Binaries/
Intermediate/
Saved/
DerivedDataCache/
FileOpenOrder/

# 忽略 VS 临时文件
.vs/
*.sln
*.vc.db
*.opendb
#第三方大模型
Content/ExternalAssets/

# 忽略所有美术资产包（如 MedCastle）
Content/MedCastle/
Content/IdaFaber/
Content/Maps/
# 以及其他不是你写的第三方文件夹...

# 忽略虚幻 5 世界分区的外部对象（这些文件非常多，如果不打算传完整地图可以忽略）
__ExternalObjects__/
__ExternalActors__/

# 必须忽略的缓存
Binaries/
Intermediate/
Saved/
DerivedDataCache/
.vs/
